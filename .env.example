# Copy this file to .env.local and fill in real values.
# .env.local is gitignored via *.local — never commit real keys.

# Gemini API key — get one at https://aistudio.google.com/apikey
# Real Gemini keys start with "AIzaSy..." and are 39 chars long.
GEMINI_API_KEY=

# Optional: HTTP(S) proxy for outbound calls (useful for Mainland dev machines
# that cannot reach generativelanguage.googleapis.com directly).
# Example: http://127.0.0.1:7890
# HTTPS_PROXY=
